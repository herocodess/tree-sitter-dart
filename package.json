{
  "name": "@driftlog/tree-sitter-dart",
  "version": "1.0.2",
  "description": "Dart grammar for tree-sitter",
  "main": "index.js",
  "types": "index.d.ts",
  "keywords": [
    "tree-sitter",
    "parser",
    "dart"
  ],
  "files": [
    "bindings/node/",
    "src/",
    "prebuilds/",
    "binding.gyp",
    "index.js",
    "index.d.ts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "contributors": [
    "Benjamin Sobel",
    "Tim Whiting <tim.a.whiting@gmail.com>",
    "Stephan Seitz <stephan.seitz@fau.de>",
    "Martin Jambon <github@mjambon.com>",
    "Kyosuke Takayama @ktakayama",
    "Han Wang @hanwangio",
    "@akinsho",
    "@seb-bl"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/herocodess/tree-sitter-dart.git"
  },
  "bugs": {
    "url": "https://github.com/herocodess/tree-sitter-dart/issues"
  },
  "homepage": "https://github.com/herocodess/tree-sitter-dart#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.1"
  },
  "peerDependencies": {
    "tree-sitter": ">=0.22.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "node-gyp": "^10.2.0",
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "^0.25.10"
  },
  "scripts": {
    "install": "node-gyp-build",
    "prebuild": "prebuildify --napi --strip --name node.napi",
    "test": "node test/integration.js"
  },
  "tree-sitter": [
    {
      "scope": "source.dart",
      "file-types": [
        "dart"
      ],
      "highlights": "queries/highlights.scm",
      "tags": [
        "queries/tags.scm"
      ],
      "injection-regex": "dart"
    }
  ]
}
